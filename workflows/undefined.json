t parts = path.split('.');\\n    let current = obj;\\n\\n    for (let i = 0; i < parts.length - 1; i++) {\\n      if (!current || typeof current !== 'object') {\\n        current = null;\\n        break;\\n      }\\n      current = current[parts[i]];\\n    }\\n\\n    if (current && typeof current === 'object') {\\n      delete current[parts[parts.length - 1]];\\n    }\\n  }\\n}\\n\\nfunction sortObjectKeys(obj) {\\n  if (Array.isArray(obj)) return obj.map(sortObjectKeys);\\n\\n  if (obj && typeof obj === 'object') {\\n    const sorted = {};\\n    Object.keys(obj).sort().forEach((key) => {\\n      sorted[key] = sortObjectKeys(obj[key]);\\n    });\\n    return sorted;\\n  }\\n\\n  return obj;\\n}\\n\\nfunction normalizeWorkflow(obj) {\\n  const copy = deepClone(obj);\\n\\n  removePaths(copy, [\\n    'updatedAt',\\n    'createdAt',\\n    'versionId',\\n    'activeVersionId',\\n    'triggerCount',\\n    'shared',\\n    'meta',\\n    'staticData',\\n  ]);\\n\\n  if (copy.activeVersion && typeof copy.activeVersion === 'object') {\\n    removePaths(copy, [\\n      'activeVersion.updatedAt',\\n      'activeVersion.createdAt',\\n      'activeVersion.versionId',\\n      'activeVersion.workflowId',\\n      'activeVersion.name',\\n      'activeVersion.description',\\n      'activeVersion.authors',\\n      'activeVersion.autosaved',\\n    ]);\\n  }\\n\\n  return sortObjectKeys(copy);\\n}\\n\\nfunction sanitizeForGitHub(obj) {\\n  let text = JSON.stringify(obj, null, 2);\\n\\n  text = text.replace(/apify_api_[A-Za-z0-9]+/gi, 'APIFY_TOKEN_MASKED');\\n  text = text.replace(/(\\\"APIFY_TOKEN_MASKED\\\"\\\\s*:\\\\s*)\\\"[^\\\"]*\\\"/gi, '$1\\\"APIFY_TOKEN_MASKED\\\"');\\n\\n  text = text.replace(/sb_secret_[A-Za-z0-9_\\\\-]+/g, 'SUPABASE_SECRET_MASKED');\\n  text = text.replace(/(\\\"apikey\\\"\\\\s*:\\\\s*)\\\"[^\\\"]*\\\"/gi, '$1\\\"SUPABASE_SECRET_MASKED\\\"');\\n  text = text.replace(/(\\\"Authorization\\\"\\\\s*:\\\\s*)\\\"Bearer [^\\\"]*\\\"/gi, '$1\\\"Bearer SUPABASE_SECRET_MASKED\\\"');\\n\\n  text = text.replace(\\n    /(\\\"(accessToken|token|secret|clientSecret|service_role|serviceRoleKey|anonKey|apiKey|x-api-key|x_api_key)\\\"\\\\s*:\\\\s*)\\\"[^\\\"]*\\\"/gi,\\n    '$1\\\"__REDACTED__\\\"'\\n  );\\n\\n  text = text.replace(/\\\\beyJ[A-Za-z0-9_\\\\-]+\\\\.[A-Za-z0-9_\\\\-]+\\\\.[A-Za-z0-9_\\\\-]+\\\\b/g, 'JWT_MASKED');\\n\\n  return text;\\n}\\n\\n// MUY IMPORTANTE:\\n// coge el workflow original completo desde el nodo que lo encontró\\nconst workflow = $node[\\\"Edit Fields1\\\"].json.workflow || $json.workflow || $json;\\n\\nconst normalized = normalizeWorkflow(workflow);\\nconst n8n_data_stringy = sanitizeForGitHub(normalized);\\n\\nreturn [\\n  {\\n    json: {\\n      name: workflow.name,\\n      id: workflow.id,\\n      filePath: \\\"workflows/\\\" + workflow.name + \\\".json\\\",\\n      workflow,\\n      n8n_data_stringy\\n    }\\n  }\\n];\"},\"type\":\"n8n-nodes-base.code\",\"typeVersion\":2,\"position\":[-416,-160],\"id\":\"96bb9290-d0f2-48d1-8e47-b765cedd2965\",\"name\":\"Code in JavaScript\"}],\"connections\":{\"Webhook\":{\"main\":[[{\"node\":\"Edit Fields\",\"type\":\"main\",\"index\":0}]]},\"Edit Fields\":{\"main\":[[{\"node\":\"Get many workflows\",\"type\":\"main\",\"index\":0}]]},\"Loop Over Items\":{\"main\":[[],[{\"node\":\"If\",\"type\":\"main\",\"index\":0}]]},\"Replace Me\":{\"main\":[[{\"node\":\"Loop Over Items\",\"type\":\"main\",\"index\":0}]]},\"If\":{\"main\":[[{\"node\":\"Edit Fields1\",\"type\":\"main\",\"index\":0}],[{\"node\":\"Replace Me\",\"type\":\"main\",\"index\":0}]]},\"Get many workflows\":{\"main\":[[{\"node\":\"Loop Over Items\",\"type\":\"main\",\"index\":0}]]},\"Edit Fields1\":{\"main\":[[{\"node\":\"Code in JavaScript\",\"type\":\"main\",\"index\":0}]]},\"Get a file\":{\"main\":[[{\"node\":\"If1\",\"type\":\"main\",\"index\":0}]]},\"If1\":{\"main\":[[{\"node\":\"Edit a file\",\"type\":\"main\",\"index\":0}],[{\"node\":\"Create a file\",\"type\":\"main\",\"index\":0}]]},\"Code in JavaScript