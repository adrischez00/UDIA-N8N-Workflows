    {
      "id": "912462c5-fde4-486a-a045-fbb0984e705a",
      "name": "Code in JavaScript",
      "parameters": {
        "jsCode": "const raw = $json.n8n_data_string || '';\n\nlet clean = raw;\n\n// Cabeceras Authorization tipo Bearer\nclean = clean.replace(\n  /\"Authorization\"\\s*:\\s*\"Bearer [^\"]+\"/gi,\n  '\"Authorization\":\"Bearer __REDACTED__\"'\n);\n\n// apiKey / apikey / x-api-key\nclean = clean.replace(\n  /\"(apiKey|apikey|x-api-key|x_api_key)\"\\s*:\\s*\"[^\"]+\"/gi,\n  '\"$1\":\"__REDACTED__\"'\n);\n\n// campos típicos sensibles\nclean = clean.replace(\n  /\"(accessToken|token|secret|clientSecret|service_role|anonKey|serviceRoleKey)\"\\s*:\\s*\"[^\"]+\"/gi,\n  '\"$1\":\"__REDACTED__\"'\n);\n\n// patrones comunes de Supabase / JWT / secrets en texto plano\nclean = clean.replace(/sb_secret_[A-Za-z0-9_\\-]+/g, '__REDACTED__');\nclean = clean.replace(/sbp_[A-Za-z0-9_\\-]+/g, '__REDACTED__');\nclean = clean.replace(/eyJ[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+/g, '__REDACTED_JWT__');\n\n// opcional: URLs firmadas o tokens largos en query params\nclean = clean.replace(/([?&](token|apikey|api_key|access_token)=)[^\"&]+/gi, '$1__REDACTED__');\n\nreturn [\n  {\n    json: {\n      ...$json,\n      n8n_data_string_sanitized: clean\n    }\n  }\n];"
      },
